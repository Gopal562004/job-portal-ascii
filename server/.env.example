PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/jobportal?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_key_here

# Email Configuration (Gmail App Password)
EMAIL_HOST=smtp.gmail.com
